{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@dde/models": ["libs/shared/models/src/index.ts"],
      "@dde/util": ["libs/shared/util/src/index.ts"],
      "@dde/ui": ["libs/shared/ui/src/index.ts"],
      "@dde/pivot-table": ["libs/pivot-table/src/index.ts"],
      "@dde/cross-tab-calculator": ["libs/cross-tab-calculator/src/index.ts"],
      "@dde/variable-editor": ["libs/variable-editor/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
