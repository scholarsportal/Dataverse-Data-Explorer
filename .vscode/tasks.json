{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "nx: serve data-explorer",
      "type": "shell",
      "command": "pnpm nx serve data-explorer",
      "isBackground": true,
      "problemMatcher": {
        "owner": "angular",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "nx run data-explorer",
          "endsPattern": "Local:.*http://localhost"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    }
  ]
}
